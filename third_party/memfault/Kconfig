menuconfig MEMFAULT
    bool "Memfault crash reporting"
    default y if RELEASE && !QEMU
    help
      Build the Memfault firmware SDK and emit the MEMFAULT=1 define
      so the firmware compiles in coredump capture, compact logs, and
      metrics collection. Defaults to y for release builds on real
      hardware; off otherwise. Override with
      --kconfig-override CONFIG_MEMFAULT=y|n.

if MEMFAULT

config MEMFAULT_FORCE
    bool "Force Memfault data collection on non-release builds"
    help
      Emit MEMFAULT_FORCE so the firmware uploads coredumps and
      metrics even when not running a release build. Only useful when
      developing the Memfault integration itself.

endif # MEMFAULT
