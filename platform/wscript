from waflib.Configure import ConfigurationContext, conf
from platform_capabilities import get_capability_dict

@conf
def get_board(ctx):
    if isinstance(ctx, ConfigurationContext):
        return ctx.options.board
    else:
        return ctx.env.BOARD

@conf
def is_bigboard(ctx):
    return '_bb' in ctx.get_board()


# Platform specific predicates

@conf
def is_spalding(ctx):
    return ctx.get_board().startswith('spalding') and ctx.get_board() != 'spalding_gabbro'

@conf
def is_silk(ctx):
    return ctx.get_board().startswith('silk')

@conf
def is_asterix(ctx):
    return ctx.get_board().startswith('asterix')

@conf
def is_obelix(ctx):
    return ctx.get_board().startswith('obelix')

@conf
def is_getafix(ctx):
    return ctx.get_board().startswith('getafix')

@conf
def is_spalding_gabbro(ctx):
    return ctx.get_board() == 'spalding_gabbro'

@conf
def is_qemu_emery(ctx):
    return ctx.get_board() == 'qemu_emery'

@conf
def is_qemu_flint(ctx):
    return ctx.get_board() == 'qemu_flint'

@conf
def is_qemu_gabbro(ctx):
    return ctx.get_board() == 'qemu_gabbro'

@conf
def is_qemu(ctx):
    return ctx.get_board().startswith('qemu_')

@conf
def get_platform_name(ctx):
    if is_qemu_emery(ctx):
        return "qemu_emery"
    elif is_qemu_flint(ctx):
        return "qemu_flint"
    elif is_qemu_gabbro(ctx):
        return "qemu_gabbro"
    elif is_spalding(ctx):
        return "spalding"
    elif is_silk(ctx):
        return "silk"
    elif is_asterix(ctx):
        return "asterix"
    elif is_obelix(ctx):
        return "obelix"
    elif is_getafix(ctx):
        return "getafix"
    elif is_spalding_gabbro(ctx):
        return "spalding_gabbro"
    else:
        return "unknown"


# Platform features

@conf
def get_qemu_machine(ctx):
    if is_qemu_emery(ctx):
        return 'pebble-emery'
    elif is_qemu_flint(ctx):
        return 'pebble-flint'
    elif is_qemu_gabbro(ctx):
        return 'pebble-gabbro'
    elif is_spalding(ctx):
        return 'pebble-s4-bb'
    elif is_silk(ctx):
        return 'pebble-silk-bb'
    elif is_spalding_gabbro(ctx):
        return 'pebble-spalding-gabbro-bb'
    else:
        return 'unknown'


@conf
def get_qemu_cpu(ctx):
    if is_qemu_emery(ctx):
        return 'cortex-m33'
    elif is_qemu_flint(ctx):
        return 'cortex-m4'
    elif is_qemu_gabbro(ctx):
        return 'cortex-m33'
    elif is_spalding(ctx):
        return 'cortex-m4'
    elif is_silk(ctx):
        return 'cortex-m4'
    elif is_asterix(ctx):
        return 'cortex-m4'
    elif is_spalding_gabbro(ctx):
        return 'cortex-m4'
    else:
        return 'unknown'


@conf
def get_qemu_spi_flash_args(ctx, spi_flash_path, qemu_major):
    if is_qemu(ctx):
        return ['-drive', 'if=mtd,format=raw,file={}'.format(spi_flash_path)]
    elif is_spalding(ctx) or is_spalding_gabbro(ctx):
        # QEMU 7.0+ uses a named block device; older versions use -pflash.
        if qemu_major >= 7:
            return ['-drive', 'if=none,id=spi-flash,file={},format=raw'.format(spi_flash_path)]
        else:
            return ['-pflash', spi_flash_path]
    elif is_silk(ctx):
        return ['-mtdblock', spi_flash_path]
    else:
        return None

@conf
def capabilities_dict(ctx):
    board = ctx.get_board()
    # capabilities will never be None. An exception is raised if it fails.
    capabilities = get_capability_dict(ctx, board)
    return capabilities


@conf
def capability(ctx, capability_str):
    capabilities = ctx.capabilities_dict()
    return capabilities[capability_str]


@conf
def add_platform_defines(ctx, env):
    if ctx.is_qemu_emery():
        bit_depth = 8
        platform = 'QEMU_EMERY'
    elif ctx.is_qemu_flint():
        bit_depth = 1
        platform = 'QEMU_FLINT'
    elif ctx.is_qemu_gabbro():
        bit_depth = 8
        platform = 'QEMU_GABBRO'
    elif ctx.is_spalding():
        bit_depth = 8
        platform = 'SPALDING'
    elif ctx.is_silk():
        bit_depth = 1
        platform = 'SILK'
    elif ctx.is_asterix():
        bit_depth = 1
        platform = 'ASTERIX'
    elif ctx.is_obelix():
        bit_depth = 8
        platform = 'OBELIX'
    elif ctx.is_getafix():
        bit_depth = 8
        platform = 'GETAFIX'
    elif ctx.is_spalding_gabbro():
        bit_depth = 8
        platform = 'SPALDING_GABBRO'
    else:
        ctx.fatal('No platform specified for {}!'.format(ctx.options.board))

    defines = ['BOARD_{}=1'.format(ctx.options.board.upper()),
               'PLATFORM_{}=1'.format(platform),
               'MICRO_FAMILY_{}=1'.format(env.MICRO_FAMILY),
               'SCREEN_COLOR_DEPTH_BITS={}'.format(bit_depth),
               'MIN_SDK_VERSION={}'.format(env.MIN_SDK_VERSION)]
    # Add umbrella MICRO_FAMILY_QEMU define for all QEMU boards
    if env.MICRO_FAMILY.startswith('QEMU_PEBBLE'):
        defines.append('MICRO_FAMILY_QEMU=1')
    env.append_value('DEFINES', defines)

    for cap, val in ctx.capabilities_dict().items():
        env.append_value('DEFINES', "CAPABILITY_%s=%s" % (cap, int(val)))

# Build

def configure(ctx):
    pass


def build(ctx):
    pass


