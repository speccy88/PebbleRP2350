# Fruit Jam ESP32-C6 BLE controller firmware.
CONFIG_BT_ENABLED=y
CONFIG_BT_CONTROLLER_ONLY=y
CONFIG_BT_LE_HCI_INTERFACE_USE_UART=y
CONFIG_BT_LE_UART_HCI_NO_DMA_MODE=y
CONFIG_BT_LE_HCI_UART_PORT=1
CONFIG_BT_LE_HCI_UART_TX_PIN=16
CONFIG_BT_LE_HCI_UART_RX_PIN=17
CONFIG_BT_LE_HCI_UART_BAUD=115200
# CONFIG_BT_LE_HCI_UART_FLOWCTRL is not set

# UART1 is the HCI data path on Fruit Jam, so keep firmware chatter off it.
CONFIG_ESP_CONSOLE_NONE=y
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y
CONFIG_BOOTLOADER_LOG_LEVEL_NONE=y
CONFIG_LOG_DEFAULT_LEVEL_NONE=y
CONFIG_ESP_SYSTEM_PANIC_SILENT_REBOOT=y

CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
