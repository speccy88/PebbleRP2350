def configure(conf):
    conf.recurse('common')
    conf.recurse('normal')
    conf.recurse('prf')

def build(bld):
    bld.env.SERVICES = []
    bld.env.SERVICES_TEXT = []
    bld.recurse('common')
    if bld.variant == 'prf':
        bld.recurse('prf')
    else:
        bld.recurse('normal')

    use = ['fw_includes']
    use.extend(bld.env.SERVICES)

    sources = ['services.c']

    bld.stlib(source=sources,
                target='fw_services',
                use=use)

    if bld.env.SERVICES_TEXT:
        bld.msgcat(source=bld.env.SERVICES_TEXT, target='services.pot')

