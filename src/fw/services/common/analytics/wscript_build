use = ['fw_includes']
sources = ['analytics.c']

if bld.env.VARIANT != 'prf':
    sources.append('native.c')
    bld.env.DEFINES.append('ANALYTICS_NATIVE')

if bld.env.memfault:
    use.append('memfault_includes')
    sources.append('memfault.c')
    bld.env.DEFINES.append('ANALYTICS_MEMFAULT')

bld.stlib(
    source=sources,
    target='services_common_analytics',
    use=use
)

bld.env.SERVICES.append('services_common_analytics')