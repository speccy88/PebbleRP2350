def configure(conf):
    conf.recurse('activity')
    conf.recurse('alarms')
    conf.recurse('app_glances')
    conf.recurse('app_message')
    conf.recurse('blob_db')
    conf.recurse('bluetooth')
    conf.recurse('comm_session')
    conf.recurse('contacts')
    conf.recurse('data_logging')
    conf.recurse('filesystem')
    conf.recurse('legacy')
    conf.recurse('notifications')
    conf.recurse('process_management')
    conf.recurse('protobuf_log')
    conf.recurse('settings')
    conf.recurse('timeline')
    conf.recurse('vibes')
    conf.recurse('voice')
    conf.recurse('weather')


def build(bld):
    bld.recurse('activity')
    bld.recurse('alarms')
    bld.recurse('app_glances')
    bld.recurse('app_message')
    bld.recurse('blob_db')
    bld.recurse('bluetooth')
    bld.recurse('comm_session')
    bld.recurse('contacts')
    bld.recurse('data_logging')
    bld.recurse('filesystem')
    bld.recurse('legacy')
    bld.recurse('notifications')
    bld.recurse('process_management')
    bld.recurse('protobuf_log')
    bld.recurse('settings')
    bld.recurse('timeline')
    bld.recurse('vibes')
    bld.recurse('voice')
    bld.recurse('weather')

    bld.stlib(
        use=['fw_includes'],
        source=['app_cache.c'],
        target='services_normal_app_cache',
    )
    bld.env.SERVICES.append('services_normal_app_cache')

    bld.stlib(
        use=['fw_includes'],
        source=['app_fetch_endpoint.c'],
        target='services_normal_app_fetch_endpoint',
    )
    bld.env.SERVICES.append('services_normal_app_fetch_endpoint')

    bld.stlib(
        use=['fw_includes'],
        source=['app_inbox_service.c'],
        target='services_normal_app_inbox_service',
    )
    bld.env.SERVICES.append('services_normal_app_inbox_service')

    bld.stlib(
        use=['fw_includes'],
        source=['app_order_endpoint.c'],
        target='services_normal_app_order_endpoint',
    )
    bld.env.SERVICES.append('services_normal_app_order_endpoint')

    bld.stlib(
        use=['fw_includes'],
        source=['app_outbox_service.c'],
        target='services_normal_app_outbox_service',
    )
    bld.env.SERVICES.append('services_normal_app_outbox_service')

    bld.stlib(
        use=['fw_includes'],
        source=['audio_endpoint.c'],
        target='services_normal_audio_endpoint',
    )
    bld.env.SERVICES.append('services_normal_audio_endpoint')

    bld.stlib(
        use=['fw_includes'],
        source=['health_sync_endpoint.c'],
        target='services_normal_health_sync_endpoint',
    )
    bld.env.SERVICES.append('services_normal_health_sync_endpoint')

    bld.stlib(
        use=['fw_includes'],
        source=['music.c', 'music_endpoint.c'],
        target='services_normal_music',
    )
    bld.env.SERVICES.append('services_normal_music')

    bld.stlib(
        use=['fw_includes'],
        source=['orientation_manager.c'],
        target='services_normal_orientation_manager',
    )
    bld.env.SERVICES.append('services_normal_orientation_manager')

    bld.stlib(
        use=['fw_includes'],
        source=['persist.c'],
        target='services_normal_persist',
    )
    bld.env.SERVICES.append('services_normal_persist')

    bld.stlib(
        use=['fw_includes', 'services_common_analytics'],
        source=['phone_call.c', 'phone_call_util.c'],
        target='services_normal_phone_call',
    )
    bld.env.SERVICES.append('services_normal_phone_call')

    bld.stlib(
        use=['fw_includes'],
        source=['send_text_service.c'],
        target='services_normal_send_text_service',
    )
    bld.env.SERVICES.append('services_normal_send_text_service')

    bld.stlib(
        use=['fw_includes'],
        source=['services_normal.c'],
        target='services_normal_services_normal',
    )
    bld.env.SERVICES.append('services_normal_services_normal')

    bld.stlib(
        use=['fw_includes', 'services_common_analytics'],
        source=['stationary.c'],
        target='services_normal_stationary',
    )
    bld.env.SERVICES.append('services_normal_stationary')

    bld.stlib(
        use=['fw_includes'],
