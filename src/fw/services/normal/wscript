    bld.env.SERVICES.append('services_normal_voice_endpoint')

    bld.stlib(
        use=['fw_includes'],
        source=['wakeup.c'],
        target='services_normal_wakeup',
    )
    bld.env.SERVICES.append('services_normal_wakeup')
