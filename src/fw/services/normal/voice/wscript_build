sources = [
    'transcription.c',
    'voice.c',
    'voice_speex.c',
]

bld.stlib(
    use=['fw_includes', 'speex_includes'],
    source=sources,
    target='services_normal_voice',
)

bld.env.SERVICES.append('services_normal_voice')

if bld.env.VOICE_CODEC_TESTS:
    voice_sample_target = bld.path.get_bld().make_node('voice_test_sample.auto.h')
    bld(
        features='binary_header',
        source='sample.pcm',
        target=voice_sample_target,
        array_name='s_voice_test_sample'
    )