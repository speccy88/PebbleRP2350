rsource "soc/Kconfig"
rsource "apps/Kconfig"
rsource "drivers/Kconfig"
rsource "kernel/Kconfig"
rsource "services/Kconfig"

menu "Software Features"

config SETTINGS_ICONS
    bool "Settings menu icons"
    help
      Show icons next to entries in the system Settings menu.

config THEMING
    bool "Color theming"
    help
      Expose the highlight-color theming UI under Settings.

config DYNAMIC_BACKLIGHT
    bool "Dynamic backlight"
    help
      Adjust backlight intensity based on ambient light readings.
      Requires an ambient light sensor.

config ACCEL_SENSITIVITY
    bool "Accelerometer sensitivity setting"
    help
      Expose the accelerometer tap/shake sensitivity adjustment in
      Settings.

config APP_SCALING
    bool "App scaling"
    help
      Scale legacy lower-resolution apps to the current display via
      the compositor.

config ORIENTATION_MANAGER
    bool "Orientation manager UI"
    help
      Expose the device-orientation / rotation prefs in shell and
      Settings. Independent of CONFIG_SERVICE_ORIENTATION_MANAGER,
      which controls whether the underlying service is built.

config MODDABLE_XS
    bool "Moddable XS JavaScript engine"
    help
      Build Moddable XS support for running JavaScript apps. PRF
      variant builds force this off regardless of the board default.

config MMAP_RESOURCES
    bool "Memory-mapped (zero-copy) resource reads"
    help
      Serve read-only system resources as direct pointers into
      memory-mapped flash instead of copying them out.

endmenu

choice
    prompt "Shell"
    default SHELL_NORMAL

config SHELL_NORMAL
    bool "Normal shell"

config SHELL_SDK
    bool "SDK shell"
    help
      Use the SDK shell instead of the normal shell.

endchoice

menu "Logging"

config LOG
    bool "Logging"
    default y
    help
      Build the PBL_LOG macros. Disable to save space.

config LOG_HASHED
    bool "Hashed logs"
    default y
    depends on LOG && !QEMU
    help
      Replace log format strings with hashes to save space. Disable
      for human-readable logs.

choice
    prompt "Default log level"
    default DEFAULT_LOG_LEVEL_DEBUG

config DEFAULT_LOG_LEVEL_ERROR
    bool "Error"

config DEFAULT_LOG_LEVEL_WARNING
    bool "Warning"

config DEFAULT_LOG_LEVEL_INFO
    bool "Info"

config DEFAULT_LOG_LEVEL_DEBUG
    bool "Debug"

config DEFAULT_LOG_LEVEL_DEBUG_VERBOSE
    bool "Debug verbose"

endchoice

choice
    prompt "Flash log level"
    default FLASH_LOG_LEVEL_INFO

config FLASH_LOG_LEVEL_ERROR
    bool "Error"

config FLASH_LOG_LEVEL_WARNING
    bool "Warning"

config FLASH_LOG_LEVEL_INFO
    bool "Info"

config FLASH_LOG_LEVEL_DEBUG
    bool "Debug"

config FLASH_LOG_LEVEL_DEBUG_VERBOSE
    bool "Debug verbose"

endchoice

config PULSE_EVERYWHERE
    bool "PULSE everywhere"
    default y if !RELEASE || MFG
    help
      Use the PULSE protocol for logs and the prompt. Disable to fall
      back to legacy logs and prompt.

endmenu

menu "Debug & instrumentation"

config NOSLEEP
    bool "Disable sleep mode"
    help
      Keep the MCU out of sleep mode so JTAG+GDB stay usable.

config NOSTOP
    bool "Disable stop mode"
    help
      Keep the MCU out of stop mode so JTAG+GDB stay usable.

config NO_WATCH_TIMEOUT
    bool "Disable watchface idle timeout"

config NO_WATCHDOG
    bool "Disable watchdog reboots"
    help
      Do not reboot automatically when a watchdog fires; break into
      the debugger instead.

config UI_DEBUG
    bool "UI debug commands"
    help
      Enable the window dump and layer nudge CLI commands.

config PROMPT
    bool "Serial console prompt"
    default y
    help
      Build the serial console. Disable to save space.

config MALLOC_INSTRUMENTATION
    bool "Malloc instrumentation"
    help
      Track the caller PC of every heap allocation.

config PROFILER
    bool "Profiler"
    select NOSTOP

config PROFILE_INTERRUPTS
    bool "Profile all interrupts"
    select PROFILER

config PERFORMANCE_TESTS
    bool "Performance test instrumentation"
    select PROFILER

endmenu
