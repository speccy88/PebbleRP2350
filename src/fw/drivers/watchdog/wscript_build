sources = []
use = ['fw_includes', 'pbl_includes']

if bld.env.CONFIG_WATCHDOG_QEMU:
    sources.append('../stubs/watchdog.c')
elif bld.env.CONFIG_WATCHDOG_NRF5:
    sources.append('nrf5.c')
    use.append('hal_nordic')
elif bld.env.CONFIG_WATCHDOG_SF32LB:
    sources.append('sf32lb.c')
    use.append('hal_sifli')

bld.objects(
    name='driver_watchdog',
    source=sources,
    use=use,
)

bld.env.DRIVERS.append('driver_watchdog')
