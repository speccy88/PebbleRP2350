sources = []
use = ['fw_includes', 'pbl_includes']

if bld.env.QEMU:
    sources.append('../stubs/touch.c')
elif bld.env.CONFIG_TOUCH_CST816:
    sources.append('cst816/cst816.c')
    use.extend([
        'cst816_fw',
        'driver_gpio',
        'freertos',
    ])

bld.objects(
    name='driver_touch',
    source=sources,
    use=use,
)

bld.env.DRIVERS.append('driver_touch')
