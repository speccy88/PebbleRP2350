sources = []
use = ['fw_includes']

if bld.env.CONFIG_TEMPERATURE_SF32LB:
    sources.append('sf32lb.c')
elif bld.env.CONFIG_TEMPERATURE_STM32F4:
    sources.append('stm32f4.c')
    use.extend([
        'driver_gpio',
        'driver_periph_config',
        'pbl_includes',
        'stm32_stdlib',
    ])
elif bld.env.CONFIG_TEMPERATURE_STUB:
    sources.append('stubs.c')

bld.objects(
    name='driver_temperature',
    source=sources,
    use=use,
)

bld.env.DRIVERS.append('driver_temperature')
