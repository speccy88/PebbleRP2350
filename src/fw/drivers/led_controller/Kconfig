menuconfig LED_CONTROLLER
    bool "LED Controller"
    help
      LED Controller Drivers

if LED_CONTROLLER

config LED_CONTROLLER_AW2016
    bool "AW2016"
    depends on I2C
    help
      Support for the AW2016 LED controller.

config LED_CONTROLLER_AW9364E
    bool "AW9364E"
    help
      Support for the AW9364E LED controller.

config LED_CONTROLLER_QEMU
    bool "QEMU"
    help
      Emulated RGB backlight controller that writes to the QEMU
      pebble-display MMIO registers.

endif # LED_CONTROLLER