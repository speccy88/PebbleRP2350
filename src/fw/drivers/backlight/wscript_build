sources = ['console.c']
use = ['fw_includes']

if bld.env.CONFIG_BACKLIGHT_AW2016:
    sources.append('aw2016.c')
elif bld.env.CONFIG_BACKLIGHT_AW9364E:
    sources.append('aw9364e.c')
elif bld.env.CONFIG_BACKLIGHT_PWM:
    sources.append('pwm.c')
elif bld.env.CONFIG_BACKLIGHT_QEMU:
    sources.append('qemu.c')

bld.objects(
    name='driver_backlight',
    source=sources,
    use=use,
)

bld.env.DRIVERS.append('driver_backlight')