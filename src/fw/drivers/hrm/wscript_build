sources = []
use = ['fw_includes']

if bld.env.CONFIG_HRM_GH3X2X:
    sources.append('gh3x2x/gh3x2x.c')
    if bld.variant != 'prf' or bld.env.IS_MFG:
        bld.env.DEFINES.append('HRM_USE_GH3X2X')
        use.append('gh3x2x')
elif bld.env.CONFIG_HRM_STUB:
    sources.append('../stubs/hrm.c')

bld.objects(
    name='driver_hrm',
    source=sources,
    use=use,
)

bld.env.DRIVERS.append('driver_hrm')
