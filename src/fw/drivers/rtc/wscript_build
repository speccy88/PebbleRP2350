sources = []
use = ['freertos', 'fw_includes', 'pbl_includes']

if bld.env.CONFIG_RTC_QEMU:
    sources.append('../qemu/qemu_rtc_hal.c')
elif bld.env.CONFIG_RTC_NRF5:
    sources.append('nrf5.c')
elif bld.env.CONFIG_RTC_SF32LB:
    sources.append('sf32lb.c')
    use.append('hal_sifli')

bld.objects(
    name='driver_rtc',
    source=sources,
    use=use,
)

bld.env.DRIVERS.append('driver_rtc')
