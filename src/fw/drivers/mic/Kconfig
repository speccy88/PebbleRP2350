menuconfig MIC
    bool "Microphone"
    help
      Microphone Drivers

if MIC

config MIC_NRF5
    bool "Nordic nRF5 PDM"
    help
      Support for the Nordic nRF5 PDM microphone interface.

config MIC_SF32LB
    bool "SiFli SF32LB PDM"
    help
      Support for the SiFli SF32LB PDM microphone interface.

config MIC_QEMU
    bool "QEMU stub"
    help
      Software-only microphone stub for QEMU. Delivers silence at
      MIC_SAMPLE_RATE so the voice service can run end-to-end against
      `pebble transcribe`, which ignores audio frames and replies with
      a canned transcription on a timer.

endif # MIC
