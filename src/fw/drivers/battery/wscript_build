sources = ['battery_common.c']
use = ['fw_includes', 'pbl_includes']

if bld.env.CONFIG_BATTERY_QEMU:
    sources.extend([
        '../qemu/qemu_battery.c',
    ])
    use.extend([
        'driver_qemu_serial',
        'driver_qemu_settings',
    ])
elif bld.env.CONFIG_BATTERY_PMIC:
    pass

bld.objects(
    name='driver_battery',
    source=sources,
    use=use,
)

bld.env.DRIVERS.append('driver_battery')
